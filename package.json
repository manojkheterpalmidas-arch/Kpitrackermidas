{
  "name": "team-kpi-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first weekly KPI tracker for Windows, starting as a localhost browser app.",
  "scripts": {
    "dev": "pnpm build && node dist/server/index.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}

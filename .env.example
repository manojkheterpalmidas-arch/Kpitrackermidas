# Local app defaults
PORT=4173

# Web deployment
# Use 0.0.0.0 on Render/Railway/Fly/etc. Leave blank for local portable mode.
HOST=0.0.0.0

# Supabase backend. If these are not set, the app falls back to local SQLite.
# You can use either the project URL or the REST endpoint URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required if you store AI API keys in Supabase mode.
# Use a long random value and keep it stable across deploys.
APP_SECRET=replace-with-a-long-random-secret
